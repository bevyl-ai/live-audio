{
  "name": "@bevyl-ai/live-audio",
  "version": "0.1.1",
  "description": "Realtime browser audio recording, waveform capture, transcription, and upload lifecycle hooks.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Bevyl",
    "url": "https://bevyl.ai"
  },
  "homepage": "https://github.com/bevyl-ai/live-audio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bevyl-ai/live-audio.git",
    "directory": "packages/live-audio"
  },
  "bugs": {
    "url": "https://github.com/bevyl-ai/live-audio/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules dist",
    "clean:dist": "rm -rf dist",
    "build": "bun run clean:dist && tsc -p tsconfig.build.json && node ../../scripts/rewrite-dist-imports.mjs",
    "format": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "lint": "tsc --noEmit",
    "pack:smoke": "node ../../scripts/smoke-packed-package.mjs",
    "prepack": "bun run build",
    "test": "bun test",
    "test:unit": "bun test --only-failures",
    "test:unit:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./audio-waveform": {
      "types": "./dist/audio-waveform/index.d.ts",
      "import": "./dist/audio-waveform/index.js",
      "default": "./dist/audio-waveform/index.js"
    },
    "./plugins/assemblyai": {
      "types": "./dist/plugins/assemblyai/index.d.ts",
      "import": "./dist/plugins/assemblyai/index.js",
      "default": "./dist/plugins/assemblyai/index.js"
    }
  },
  "dependencies": {
    "mediabunny": "1.46.0",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.14",
    "happy-dom": "^20.0.11",
    "prettier": "^3.8.3",
    "react": "19.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
